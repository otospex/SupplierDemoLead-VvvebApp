# Default-deny — only paths explicitly un-ignored below are sent to the Docker build context.
# Keeps the build small and prevents accidentally shipping local artifacts (storage, node_modules, .git, etc.).
*

# Files needed by Dockerfile / Dockerfile.dokploy:
!php.ini
!init.dokploy.sh
!seed.dokploy.php
!seed.dokploy.sql

# Site config (per-language homepage template) — overlaid so /fr/ uses index.fr.html.
!config
config/*
!config/sites.php

# Content controller carrying the language-suffixed-template fallback that
# localizes sub-page / post chrome (content/<name>.<lang>.html).
!app
app/*
!app/controller
app/controller/*
!app/controller/index.php
!app/controller/content
app/controller/content/*
!app/controller/content/post.php

# Custom plugin sources + browser-served assets (Dockerfile.dokploy COPYs these).
!plugins
!plugins/lead-platform-connector
!plugins/lead-platform-connector/**
!public
!public/plugins
!public/plugins/lead-platform-connector
!public/plugins/lead-platform-connector/**

# Theme overrides.
!public/themes
!public/themes/landing
!public/themes/landing/**
!public/themes/souverainete-digitale
!public/themes/souverainete-digitale/**

# Re-ignore noisy subdirs that may live inside the un-ignored paths.
**/.git
**/.DS_Store
**/node_modules
**/storage/cache/*
**/storage/compiled-templates/*
