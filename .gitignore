storage/compiled-templates/*
storage/cache/*
config/db.php
docs/superpowers/plans/scripts/db-backup-*
app/model/*
admin/model/*
public/image-cache/*
!public/image-cache/.gitkeep
public/page-cache/*
public/themes/*/*.html
!public/themes/*/src/*.html
!public/themes/souverainete-digitale/*.html
public/admin/themes/*/*.html
!public/admin/themes/*/src/*.html

# Editor save-snapshots (auto-generated on every page save)
public/themes/*/backup/
public/admin/themes/*/backup/

# Lead Platform Connector — encryption key (per-environment secret)
storage/lead-platform-connector.key

# One-time DB seed marker (written into the persistent volume at runtime;
# must never be committed or it will make the seeder skip on a fresh deploy)
storage/.seed-souverainete-applied
storage/.seed-souverainete-applied-v2

# vtpl backup files (created during editor development)
system/vtpl/*.bak
.codelite
vendor
node_modules
*.map.*
*.phprj
*.workspace
